{
  "name": "aero-systems-prep",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build:og": "tsx scripts/generate-og-images.ts",
    "build:pwa-icons": "tsx scripts/generate-pwa-icons.ts",
    "build": "tsc --noEmit && vite build && tsx scripts/generate-og-images.ts && tsx scripts/prerender.ts && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report",
    "postinstall": "node scripts/patch-vercel-node-deps.cjs"
  },
  "dependencies": {
    "@fontsource/geist-sans": "^5.2.5",
    "@fontsource/instrument-serif": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@google/genai": "^1.29.0",
    "@sentry/react": "^10.56.0",
    "@sentry/vite-plugin": "^5.3.0",
    "@sparticuz/chromium": "^149.0.0",
    "@supabase/supabase-js": "^2.106.1",
    "@tailwindcss/vite": "^4.1.14",
    "@upstash/qstash": "^2.11.0",
    "@upstash/redis": "^1.38.0",
    "@vercel/speed-insights": "^2.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "d3": "^7.9.0",
    "express": "^4.22.2",
    "focus-trap-react": "^12.0.2",
    "inngest": "^4.5.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "papaparse": "^5.5.3",
    "posthog-js": "^1.378.1",
    "puppeteer-core": "^25.1.0",
    "razorpay": "^2.9.6",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-router-dom": "^7.15.1",
    "recharts": "^3.8.1",
    "vite": "^6.2.3"
  },
  "overrides": {
    "node-domexception": "file:packages/node-domexception",
    "minimatch": "^10.2.5",
    "@vercel/node": {
      "path-to-regexp": "^6.3.0",
      "esbuild": "^0.28.1",
      "tsx": "^4.22.4"
    },
    "undici": "^6.26.0",
    "vite": {
      "esbuild": "^0.28.1"
    },
    "esbuild": "^0.28.1",
    "smol-toml": "^1.6.1",
    "ajv": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/d3": "^7.4.3",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/papaparse": "^5.5.2",
    "@vercel/node": "^5.8.17",
    "autoprefixer": "^10.4.21",
    "beasties": "^0.4.2",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.0",
    "rollup-plugin-visualizer": "^7.0.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.22.4",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
